# Consilium environment.
# The app runs WITHOUT any of these set: it falls back to deterministic stub
# mode (in-memory store + mock CDS engine), mirroring how you can demo the
# whole flow with zero keys. Add keys to graduate each subsystem to real infra.

# --- LLM (CDS reasoning) ---
# When unset, the engine returns a deterministic mock response. PHI is only ever
# sent transiently for inference; never log prompts that contain PHI to disk.
ANTHROPIC_API_KEY=
CDS_MODEL=claude-opus-4-7

# --- Supabase (Postgres + Auth + RLS) ---
# When unset, the data layer uses the in-memory store seeded with one demo case.
# Use the SERVICE ROLE key only on the server; never expose it to the client.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- App ---
# Default guideline framework when a clinician has not chosen one.
DEFAULT_GUIDELINE_FRAMEWORK=US
